# Polymarket CLOB credentials (never commit real values)
# Wallet private key — hex with or without 0x prefix
PK=your_private_key_here

# Signature type:
#   0 = EOA (MetaMask / hardware wallet)
#   1 = Email / Magic
#   2 = Browser proxy / Gnosis Safe (most Polymarket.com accounts)
SIGNATURE_TYPE=0

# Address that holds funds (required for signature types 1 and 2; often your Polymarket proxy wallet)
FUNDER_ADDRESS=

# Live trading: set to false to place real orders (defaults true if unset).
# DRY_RUN must be manually set to false to risk real funds.
DRY_RUN=true
